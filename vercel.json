{
  "version": 2,
  "env": {
    "YOUTUBE_DL_FILENAME": "yt-dlp_linux",
    "YOUTUBE_DL_SKIP_PYTHON_CHECK": "1"
  },
  "builds": [
    {
      "src": "api/[...path].js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "node_modules/ffmpeg-static/ffmpeg",
          "node_modules/youtube-dl-exec/bin/yt-dlp_linux"
        ]
      }
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/remote-clips/(.*)",
      "dest": "http://144.31.184.79/clips/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/[...path].js"
    },
    {
      "src": "/(.*\\.(?:css|js|json|svg|png|jpg|jpeg|webm|mp4))",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}
